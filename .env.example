# Backend Environment Variables
# Copy this to .env and fill with your values

# MongoDB Connection String
# Get this from MongoDB Atlas: https://cloud.mongodb.com
# Format: mongodb+srv://username:password@cluster.mongodb.net/dbname?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/tinyurl?retryWrites=true&w=majority

# Server Port
PORT=5000

# Base URL for shortened links
# Development: http://localhost:5000
# Production: https://your-domain.com or https://your-backend.railway.app
BASE_URL=http://localhost:5000
